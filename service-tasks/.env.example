# Puerto en el que correrá el Task Service
PORT=3002

# Conexión a la base de datos MongoDB (independiente del resto de servicios)
URI_MONGODB=mongodb://localhost:27017/service-tasks

# Configuración del JWT: debe ser EXACTAMENTE el mismo valor que JWT_SECRET
# en el .env del service-auth, ya que este servicio solo valida el token
# (no lo emite). El service-auth no firma con issuer ni audience.
JWT_SECRET=

# Entorno de ejecución
NODE_ENV=development
